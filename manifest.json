{
  "manifest_version": 3,
  "name": "STOPDog - Stay Focused Blocker",
  "short_name": "STOPDog",
  "version": "1.1",
  "description": "Your ultimate productivity companion. A dog will block your screen when time is up!",
  "action": {
    "default_popup": "popup.html",
    "default_title": "STOPDog Settings",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*.mp4",
        "icon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}